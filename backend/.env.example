# Server
PORT=5000
NODE_ENV=production

# MongoDB (Atlas free tier recommended for a free serverless-friendly build)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/kera-chat?retryWrites=true&w=majority

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Hugging Face - the model is NEVER loaded into this server's RAM.
# We call HF's routed Inference Providers API (serverless) instead, so a
# free instance (Render/Railway/Fly free tier etc.) never has to hold the
# model in memory. HF automatically picks a partner provider that actually
# serves the requested model.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be a model that's actually listed under "Inference Providers" on its
# HF model page (check the model page in your browser before relying on it).
HF_MODEL=google/gemma-2-2b-it
# Optional: override the full endpoint (defaults to HF's OpenAI-compatible router)
HF_INFERENCE_URL=https://router.huggingface.co/v1/chat/completions

# Image generation (the "/image <prompt>" chat command)
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# Optional: override the full endpoint
HF_IMAGE_URL=https://router.huggingface.co/hf-inference/models/black-forest-labs/FLUX.1-schnell

# Rate limiting
# A "session" starts on the user's first ever message and lasts this long.
SESSION_LIMIT_MINUTES=120
# Inside that session, at most this many messages are allowed per rolling window.
WINDOW_LIMIT_MESSAGES=25
WINDOW_LIMIT_MINUTES=30

# Sharing
SHARE_LINK_TTL_HOURS=2

# CORS - the deployed frontend origin (leave * only for local dev)
CLIENT_ORIGIN=http://localhost:5173
