# Server
PORT=5000
NODE_ENV=production

# MongoDB (Atlas free tier recommended for a free serverless-friendly build)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/kera-chat?retryWrites=true&w=majority

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Hugging Face - the model is NEVER loaded into this server's RAM.
# We use HF's official SDK, which auto-routes each request to whichever
# partner provider (Together, fal.ai, Novita, Fireworks, etc.) actually
# serves the requested model, so a free instance (Render/Railway/Fly free
# tier etc.) never has to hold model weights in memory.
#
# HF's free tier caps each account at a limited monthly quota. HF_TOKEN_2
# is an optional second account's token - if the first token's quota is
# exhausted (or any other error), requests automatically retry on the
# second token before falling back to Gemini (chat only).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_2=

# Chat model - must be listed under "Inference Providers" on its HF page
# (check the model page in your browser before relying on it).
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# Optional: pin a specific provider instead of letting HF auto-pick one,
# e.g. together / novita / fireworks-ai / hyperbolic. Leave unset normally.
HF_CHAT_PROVIDER=

# Gemini free API - last-resort chat fallback if BOTH HF tokens fail.
# Text only; never used for image generation. Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Image generation (the "/image <prompt>" chat command). Same dual-token
# fallback as chat applies here too, but there is NO Gemini fallback for
# images - Gemini is text-only in this app.
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# Image editing model, used automatically once a chat has an uploaded
# reference image ("image-based memory") - /image then edits it instead of
# generating from scratch.
HF_IMAGE_EDIT_MODEL=black-forest-labs/FLUX.1-Kontext-dev
# Optional: pin a specific provider, e.g. fal-ai / replicate / together.
HF_IMAGE_PROVIDER=

# Cloudinary - generated images are uploaded here (unsigned upload preset)
# so MongoDB only stores a short CDN URL, never the raw image data.
# Upload preset "Kera_Assets" must exist on this account with:
#   Signing mode: Unsigned | Asset folder: Kera/assets | Type: upload
#   Overwrite: false | Use filename: false | Unique filename: false
CLOUDINARY_CLOUD_NAME=o6kkyswq
CLOUDINARY_UPLOAD_PRESET=Kera_Assets

# Admin accounts (comma-separated emails) get unlimited messages - no
# session cap, no 25/30min window. Sign up with this email to get access.
ADMIN_EMAILS=websinaro@gmail.com

# Rate limiting (applies to everyone except ADMIN_EMAILS above)
# A "session" starts on the user's first ever message and lasts this long.
SESSION_LIMIT_MINUTES=120
# Inside that session, at most this many messages are allowed per rolling window.
WINDOW_LIMIT_MESSAGES=25
WINDOW_LIMIT_MINUTES=30

# Sharing
SHARE_LINK_TTL_HOURS=2

# CORS - the deployed frontend origin (leave * only for local dev)
CLIENT_ORIGIN=http://localhost:5173
